# FRED — macro data. Keyless locally (CSV); for cloud/CI set a free key
# (FRED throttles the keyless endpoint from datacenter IPs).
# https://fredaccount.stlouisfed.org/apikeys
# FRED_API_KEY=your_32_char_key

# Financial Modeling Prep — sector performance, earnings, valuation (3 signals).
# Free key: https://site.financialmodelingprep.com/developer/docs
# FMP_API_KEY=your_fmp_key

# Network resilience (raise on slow links).
# HTTP_TIMEOUT=30
# HTTP_RETRIES=4

# Backend host/port.
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8000
