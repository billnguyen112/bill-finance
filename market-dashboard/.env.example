# Copy to .env and fill in. The pipeline reads these at runtime.

# --- AI analysis -----------------------------------------------------------
# Provider: "anthropic" (real breakdown) or "stub" (no-cost, no-key fallback).
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (defaults to the latest Opus).
ANTHROPIC_MODEL=claude-opus-4-8

# --- Transcript scraping ---------------------------------------------------
# YouTube blocks transcript requests from datacenter/cloud IPs. On your own
# machine you need nothing here. In the cloud, supply a residential proxy:
#   Webshare (recommended by youtube-transcript-api):
# WEBSHARE_PROXY_USERNAME=
# WEBSHARE_PROXY_PASSWORD=
#   ...or a generic HTTP/HTTPS proxy:
# YT_HTTP_PROXY=http://user:pass@host:port
# YT_HTTPS_PROXY=http://user:pass@host:port

# --- Misc ------------------------------------------------------------------
# CHANNEL_ID=UCAHr-sT0AjrD3sBwr1eRUNg   # Mark Meldrum (default)
# SPOTLIGHT_MIN_FRACTION=0.4            # where to start looking for the spotlight cut
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8000
