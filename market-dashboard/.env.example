# Running locally on your own machine needs no keys (it scrapes FRED's public
# CSV endpoint). For cloud/CI runs (GitHub Actions), FRED throttles that
# endpoint, so set a FREE FRED API key — get one in 2 minutes at
# https://fredaccount.stlouisfed.org/apikeys
# FRED_API_KEY=your_32_char_key

# Network resilience (raise on slow links).
# HTTP_TIMEOUT=30
# HTTP_RETRIES=4

# Backend host/port.
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8000
